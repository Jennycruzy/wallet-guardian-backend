# ============================================================
# WalletGuard – Environment Configuration
# ============================================================

# ------------------------------------------------------------
# OpenGradient (https://hub.opengradient.ai)
# ------------------------------------------------------------
OPENGRADIENT_PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY
OPENGRADIENT_ALPHA_PRIVATE_KEY=
OPENGRADIENT_EMAIL=you@example.com
OPENGRADIENT_PASSWORD=your_model_hub_password
OPENGRADIENT_LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ------------------------------------------------------------
# Block Explorer
# One Etherscan API key covers all chains:
# Etherscan, Basescan, Polygonscan, Arbiscan, BscScan, Optimistic Etherscan
# Get it at: etherscan.io → My Account → API Keys
# ------------------------------------------------------------
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ------------------------------------------------------------
# Multi-chain RPC endpoints (Infura key works for all except BSC)
# Get Infura key at: app.infura.io
# BSC uses a free public RPC — no key needed
# ------------------------------------------------------------
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
ARBITRUM_RPC_URL=https://arbitrum-mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
OPTIMISM_RPC_URL=https://optimism-mainnet.infura.io/v3/YOUR_INFURA_KEY

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
